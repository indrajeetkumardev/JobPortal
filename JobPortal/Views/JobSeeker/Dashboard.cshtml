@model List<JobPortal.Models.JobApplication>

@{
    ViewData["Title"] = "My Dashboard";
    var user = ViewBag.User as JobPortal.Models.ApplicationUser;
}

<div class="container py-4">

    <!-- Welcome -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">
                👋 Welcome, @user?.FullName!
            </h4>
            <p class="text-muted mb-0">
                <i class="bi bi-geo-alt me-1"></i>@(user?.CurrentCity ?? "Location not set")
            </p>
        </div>
        <a asp-controller="Home" asp-action="Jobs"
           class="btn btn-primary">
            <i class="bi bi-search me-1"></i>Browse Jobs
        </a>
    </div>

    <!-- Stats -->
    <div class="row g-4 mb-4">
        <div class="col-6 col-md-3">
            <div class="card stat-card p-3 border-start border-primary border-4">
                <p class="text-muted small mb-1">Total Applied</p>
                <h3 class="fw-bold mb-0">@ViewBag.TotalApplications</h3>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card p-3 border-start border-warning border-4">
                <p class="text-muted small mb-1">Pending</p>
                <h3 class="fw-bold mb-0 text-warning">@ViewBag.Pending</h3>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card p-3 border-start border-success border-4">
                <p class="text-muted small mb-1">Shortlisted</p>
                <h3 class="fw-bold mb-0 text-success">@ViewBag.Shortlisted</h3>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card stat-card p-3 border-start border-danger border-4">
                <p class="text-muted small mb-1">Rejected</p>
                <h3 class="fw-bold mb-0 text-danger">@ViewBag.Rejected</h3>
            </div>
        </div>
    </div>

    <!-- Recent Applications -->
    <div class="card">
        <div class="card-header bg-white d-flex justify-content-between
                    align-items-center py-3">
            <h6 class="fw-bold mb-0">
                <i class="bi bi-clock-history text-primary me-2"></i>
                Recent Applications
            </h6>
            <a asp-action="MyApplications" class="btn btn-sm btn-outline-primary">
                View All
            </a>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-inbox text-muted" style="font-size:3rem"></i>
                    <p class="text-muted mt-2">
                        Abhi tak koi application nahi
                    </p>
                    <a asp-controller="Home" asp-action="Jobs"
                       class="btn btn-primary btn-sm">
                        Jobs Browse Karo
                    </a>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Job</th>
                            <th>Company</th>
                            <th>Applied On</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var app in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold">
                                    @app.Job?.Title
                                </td>
                                <td class="text-muted">
                                    @app.Job?.CompanyName
                                </td>
                                <td class="text-muted">
                                    @app.AppliedDate.ToString("dd MMM yyyy")
                                </td>
                                <td>
                                    @{
                                        var badgeColor = app.Status switch
                                        {
                                            "Pending" => "warning",
                                            "Reviewed" => "info",
                                            "Shortlisted" => "success",
                                            "Rejected" => "danger",
                                            _ => "secondary"
                                        };
                                    }
                                    <span class="badge bg-@badgeColor-subtle
                                                         text-@badgeColor border border-@badgeColor">
                                        @app.Status
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>