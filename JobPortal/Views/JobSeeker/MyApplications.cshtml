@model List<JobPortal.Models.JobApplication>

@{
    ViewData["Title"] = "My Applications";
}

<div class="container py-4">
    <h4 class="fw-bold mb-4">
        <i class="bi bi-file-text text-primary me-2"></i>
        My Applications (@Model.Count)
    </h4>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-inbox text-muted" style="font-size:4rem"></i>
            <h5 class="text-muted mt-3">Koi application nahi</h5>
            <a asp-controller="Home" asp-action="Jobs"
               class="btn btn-primary mt-2">Browse Jobs</a>
        </div>
    }
    else
    {
        <div class="row g-3">
            @foreach (var app in Model)
            {
                var color = app.Status switch
                {
                    "Pending" => "warning",
                    "Reviewed" => "info",
                    "Shortlisted" => "success",
                    "Rejected" => "danger",
                    _ => "secondary"
                };
                <div class="col-12">
                    <div class="card p-3 border-start border-@color border-3">
                        <div class="row align-items-center">
                            <div class="col">
                                <h6 class="fw-bold mb-1">@app.Job?.Title</h6>
                                <p class="text-muted small mb-1">
                                    <i class="bi bi-building me-1"></i>
                                    @app.Job?.CompanyName
                                    <span class="mx-2">•</span>
                                    <i class="bi bi-geo-alt me-1"></i>
                                    @app.Job?.Location
                                </p>
                                <small class="text-muted">
                                    Applied: @app.AppliedDate.ToString("dd MMM yyyy")
                                </small>
                            </div>
                            <div class="col-auto">
                                <span class="badge bg-@color-subtle 
                                             text-@color border border-@color fs-6">
                                    @app.Status
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>