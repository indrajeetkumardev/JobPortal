@model List<JobPortal.Models.Job>

@{
    ViewData["Title"] = "Employer Dashboard";
    var user = ViewBag.User as JobPortal.Models.ApplicationUser;
}

<div class="container py-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold mb-1">
                🏢 @(user?.CompanyName ?? user?.FullName)
            </h4>
            <p class="text-muted mb-0">Employer Dashboard</p>
        </div>
        <a asp-action="PostJob" class="btn btn-primary">
            <i class="bi bi-plus-circle me-1"></i>Post New Job
        </a>
    </div>

    <!-- Stats -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card stat-card p-3 border-start border-primary border-4">
                <p class="text-muted small mb-1">Total Jobs Posted</p>
                <h3 class="fw-bold mb-0">@ViewBag.TotalJobs</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card p-3 border-start border-success border-4">
                <p class="text-muted small mb-1">Active Jobs</p>
                <h3 class="fw-bold mb-0 text-success">@ViewBag.ActiveJobs</h3>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card stat-card p-3 border-start border-warning border-4">
                <p class="text-muted small mb-1">Total Applications</p>
                <h3 class="fw-bold mb-0 text-warning">@ViewBag.TotalApplications</h3>
            </div>
        </div>
    </div>

    <!-- Recent Jobs -->
    <div class="card">
        <div class="card-header bg-white d-flex justify-content-between
                    align-items-center py-3">
            <h6 class="fw-bold mb-0">
                <i class="bi bi-briefcase text-primary me-2"></i>My Jobs
            </h6>
            <a asp-action="MyJobs" class="btn btn-sm btn-outline-primary">
                View All
            </a>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center py-4">
                    <p class="text-muted">Abhi koi job post nahi ki</p>
                    <a asp-action="PostJob" class="btn btn-primary btn-sm">
                        Post First Job
                    </a>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-3">Job Title</th>
                            <th>Location</th>
                            <th>Applications</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in Model)
                        {
                            <tr>
                                <td class="ps-3 fw-semibold">@job.Title</td>
                                <td class="text-muted">@job.Location</td>
                                <td>
                                    <span class="badge bg-primary-subtle text-primary">
                                        @job.Applications.Count applicants
                                    </span>
                                </td>
                                <td>
                                    @if (job.IsActive)
                                    {
                                        <span class="badge bg-success-subtle text-success">
                                            Active
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger">
                                            Inactive
                                        </span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Applicants"
                                       asp-route-jobId="@job.Id"
                                       class="btn btn-sm btn-outline-info me-1">
                                        <i class="bi bi-people"></i>
                                    </a>
                                    <a asp-action="EditJob"
                                       asp-route-id="@job.Id"
                                       class="btn btn-sm btn-outline-warning">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>