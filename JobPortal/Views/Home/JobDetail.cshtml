@model JobPortal.Models.Job

@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <div class="row">

        <!-- Left: Main Info -->
        <div class="col-md-8">
            <div class="card p-4 mb-4">

                <!-- Header -->
                <div class="d-flex align-items-start gap-3 mb-3">
                    <div class="rounded-circle bg-primary text-white d-flex
                                align-items-center justify-content-center fw-bold"
                         style="width:60px;height:60px;font-size:1.3rem;min-width:60px">
                        @Model.CompanyName[0]
                    </div>
                    <div>
                        <h4 class="fw-bold mb-1">@Model.Title</h4>
                        <p class="text-muted mb-0">
                            <i class="bi bi-building me-1"></i>@Model.CompanyName
                            <span class="mx-2">•</span>
                            <i class="bi bi-geo-alt me-1"></i>@Model.Location
                        </p>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 mb-4">
                    <span class="badge bg-primary-subtle text-primary">
                        <i class="bi bi-briefcase me-1"></i>@Model.JobType
                    </span>
                    <span class="badge bg-info-subtle text-info">
                        <i class="bi bi-clock me-1"></i>@Model.ExperienceRequired
                    </span>
                    @if (!string.IsNullOrEmpty(Model.SalaryRange))
                    {
                        <span class="badge bg-success-subtle text-success">
                            <i class="bi bi-currency-rupee"></i>@Model.SalaryRange
                        </span>
                    }
                    <span class="badge bg-warning-subtle text-warning">
                        Last Date: @Model.LastDate.ToString("dd MMM yyyy")
                    </span>
                </div>

                <h6 class="fw-bold">Job Description</h6>
                <p class="text-muted">@Model.Description</p>

                <h6 class="fw-bold mt-3">Requirements</h6>
                <p class="text-muted">@Model.Requirements</p>

            </div>
        </div>

        <!-- Right: Apply Card -->
        <div class="col-md-4">
            <div class="card p-4 text-center mb-3">
                @if (User?.Identity?.IsAuthenticated == true && User.IsInRole("JobSeeker"))
                {
                    <i class="bi bi-send-fill text-primary mb-2"
                       style="font-size:2rem"></i>
                    <h5 class="fw-bold">Ready to Apply?</h5>
                    <p class="text-muted small">
                        Is job ke liye apply karo aur apna career banao!
                    </p>
                    <a asp-controller="JobSeeker" asp-action="Apply"
                       asp-route-id="@Model.Id"
                       class="btn btn-primary w-100">
                        <i class="bi bi-send me-1"></i>Apply Now
                    </a>
                }
                else if (User?.Identity?.IsAuthenticated != true)
                {
                    <i class="bi bi-person-lock text-muted mb-2"
                       style="font-size:2rem"></i>
                    <h5 class="fw-bold">Apply Karna Hai?</h5>
                    <p class="text-muted small">
                        Pehle login ya register karo
                    </p>
                    <a asp-controller="Account" asp-action="Login"
                       class="btn btn-primary w-100 mb-2">Login</a>
                    <a asp-controller="Account" asp-action="Register"
                       class="btn btn-outline-primary w-100">Register Free</a>
                }
                else
                {
                    <i class="bi bi-info-circle text-muted mb-2"
                       style="font-size:2rem"></i>
                    <p class="text-muted small">
                        Sirf Job Seekers apply kar sakte hain
                    </p>
                }
            </div>

            <!-- Job Meta -->
            <div class="card p-3">
                <h6 class="fw-bold mb-3">Job Details</h6>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Posted On</span>
                    <span class="small fw-semibold">
                        @Model.PostedDate.ToString("dd MMM yyyy")
                    </span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Last Date</span>
                    <span class="small fw-semibold text-danger">
                        @Model.LastDate.ToString("dd MMM yyyy")
                    </span>
                </div>
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Job Type</span>
                    <span class="small fw-semibold">@Model.JobType</span>
                </div>
            </div>
        </div>

    </div>
</div>