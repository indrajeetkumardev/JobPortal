<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — JobPortal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css"
          rel="stylesheet" />
    <style>
        :root {
            --primary: #2563eb;
            --dark: #1e293b;
        }
        body { background: #f1f5f9; font-family: 'Segoe UI', sans-serif; }

        /* Navbar */
        .navbar { background: var(--dark) !important; padding: 0.8rem 0; }
        .navbar-brand { font-size: 1.4rem; font-weight: 800; color: white !important; }
        .navbar-brand span { color: #3b82f6; }
        .nav-link { color: rgba(255,255,255,0.8) !important; font-weight: 500; }
        .nav-link:hover { color: white !important; }

        /* Cards */
        .card { border: none; box-shadow: 0 1px 8px rgba(0,0,0,0.08);
                border-radius: 12px; }

        /* Stat Cards */
        .stat-card { border-radius: 12px; transition: transform 0.2s; }
        .stat-card:hover { transform: translateY(-3px); }

        /* Badges */
        .badge { font-weight: 500; }

        /* Buttons */
        .btn { border-radius: 8px; font-weight: 500; }
        .btn-primary { background: var(--primary); border-color: var(--primary); }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <!-- NAVBAR -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">

            <!-- Brand -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-briefcase-fill me-2"></i>Job<span>Portal</span>
            </a>

            <!-- Mobile Toggle -->
            <button class="navbar-toggler" type="button"
                    data-bs-toggle="collapse" data-bs-target="#navMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navMenu">

                <!-- Left Links -->
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house me-1"></i>Home
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Jobs">
                            <i class="bi bi-search me-1"></i>Browse Jobs
                        </a>
                    </li>
                </ul>

                <!-- Right Side -->
                <ul class="navbar-nav">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <!-- Dashboard Link based on Role -->
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin"
                                   asp-action="Dashboard">
                                    <i class="bi bi-speedometer2 me-1"></i>Admin Panel
                                </a>
                            </li>
                        }
                        else if (User.IsInRole("Employer"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Employer"
                                   asp-action="Dashboard">
                                    <i class="bi bi-building me-1"></i>My Dashboard
                                </a>
                            </li>
                        }
                        else if (User.IsInRole("JobSeeker"))
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="JobSeeker"
                                   asp-action="Dashboard">
                                    <i class="bi bi-person me-1"></i>My Dashboard
                                </a>
                            </li>
                        }

                        <!-- Logout -->
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout"
                                  method="post" class="d-inline">
                                <button type="submit"
                                        class="btn btn-outline-light btn-sm ms-2">
                                    <i class="bi bi-box-arrow-right me-1"></i>Logout
                                </button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Account"
                               asp-action="Login">Login</a>
                        </li>
                        <li class="nav-item">
                            <a class="btn btn-primary btn-sm ms-2"
                               asp-controller="Account" asp-action="Register">
                                Register Free
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>
    <!-- NAVBAR END -->
    <!-- ALERTS -->
    <div class="container mt-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show shadow-sm">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show shadow-sm">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
    </div>

    <!-- CONTENT -->
    @RenderBody()

    <!-- FOOTER -->
    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container text-center">
            <p class="mb-1 fw-bold">
                <i class="bi bi-briefcase-fill me-1 text-primary"></i>JobPortal
            </p>
            <p class="text-white-50 small mb-0">
                © @DateTime.Now.Year — Find your dream job today!
            </p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>